generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id         String   @id @default(cuid())
  name       String
  headDoctor String?
  phone      String?
  roomNo     String?
  status     String   @default("Active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  mobile    String?
  address   String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Staff {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String
  relationship String
  status       String   @default("Active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Doctor {
  id                 String   @id @default(cuid())
  name               String
  speciality         String
  phone              String
  email              String   @unique
  startCareerDate    DateTime
  registrationNumber String   @unique
  consultancyFees    Decimal  @db.Decimal(10, 2)
  availableDays      String
  startTime          String
  endTime            String
  status             String   @default("Active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
