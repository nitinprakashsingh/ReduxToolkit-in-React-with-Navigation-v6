generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id         String   @id @default(cuid())
  name       String
  headDoctor String?
  phone      String?
  roomNo     String?
  status     String   @default("Active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  mobile    String?
  address   String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Staff {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String
  relationship String
  status       String   @default("Active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Doctor {
  id                 String   @id @default(cuid())
  name               String
  speciality         String
  phone              String
  email              String   @unique
  startCareerDate    DateTime
  registrationNumber String   @unique
  consultancyFees    Decimal  @db.Decimal(10, 2)
  availableDays      String
  startTime          String
  endTime            String
  status             String   @default("Active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Hospital {
  id                   String   @id @default(cuid())
  name                 String
  address              String?
  licenseNumber        String?
  yearOfCommencement   String?
  ownership            String?
  noOfAmbulance        String?
  organsOperated       String?
  specialityOperations String?
  facilities           Json?
  totalArea            String?
  emergencyAvailable   Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Patient {
  id                  String   @id @default(cuid())
  name                String
  email               String?  @unique
  phone               String?
  address             String?
  gender              String?
  dob                 String?
  age                 Int?
  medicalRecordNumber String?  @unique
  assignedDoctor      String?
  lastVisit           String?
  status              String   @default("Active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Booking {
  id                String   @id @default(cuid())
  bookingNo         String   @unique
  patientId         String?
  patientName       String
  patientEmail      String?
  patientPhone      String
  doctorId          String?
  doctorName        String
  department        String?
  appointmentDate   DateTime
  appointmentTime   String
  consultancyFees   Decimal  @db.Decimal(10, 2) @default(0)
  paymentMethod     String?  @default("Cash")
  paymentReceived   Boolean  @default(false)
  paymentAmount     Decimal  @db.Decimal(10, 2) @default(0)
  status            String   @default("Pending")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PackagePlan {
  id               String                @id @default(cuid())
  name             String
  price            Decimal               @db.Decimal(10, 2)
  duration         String
  department       String
  testsIncluded    Int
  consultancyFree  Int
  description      String
  tier             String                @unique
  durationMonths   Int
  status           String                @default("Active")
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  subscriptions    PackageSubscription[]
}

model PackageSubscription {
  id             String       @id @default(cuid())
  name           String
  phone          String
  packageName    String
  packagePlanId  String?
  packagePlan    PackagePlan? @relation(fields: [packagePlanId], references: [id])
  startDate      DateTime     @default(now())
  endDate        DateTime
  status         String       @default("Active")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
